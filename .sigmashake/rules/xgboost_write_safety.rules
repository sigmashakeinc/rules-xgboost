# xgboost_write_safety.rules
# Technology: xgboost | Capability: write

rule xgboost-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "xgboost.train("
  MESSAGE "Blocked an unsafe pattern in xgboost. Use the recommended best practices for 2025/2026."
}

rule xgboost-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "xgboost.DMatrix"
  MESSAGE "You are using an outdated API for xgboost. Please upgrade to the newer API."
}
